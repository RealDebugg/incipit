generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tags {
  id    Int     @id @default(autoincrement())
  name  String
  posts Posts[]
}

model Posts {
  id             Int      @id @default(autoincrement())
  date           DateTime @default(now())
  author         String
  title          String
  content        String
  description    String?
  coverPhotoBlob String?
  tags           Tags[]
  status         Int //0 = Draft, 1 = Published, 2 = Unpublished
}
